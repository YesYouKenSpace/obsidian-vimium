			"esbuild"
		]
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^18",
		"builtin-modules": "^5.2",
		"esbuild": "^0.25",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "latest",
		"tslib": "^2.8",
		"typescript": "^5.8",
		"typescript-eslint": "^8.62.0"
	}
